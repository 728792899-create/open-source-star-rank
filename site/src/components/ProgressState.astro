---
import type { RankingIndex } from '../types';
import { withBase } from '../lib/paths';
import FreshnessStatus from './FreshnessStatus.astro';

interface Props {
  index: RankingIndex;
  days: 7 | 30;
}

const { index, days } = Astro.props;
const progress = index.sampling?.period_progress[`${days}d`] ?? { completed: 0, required: days };
const percentage = Math.min(100, Math.round((progress.completed / progress.required) * 100));
---

<main id="main-content" class="shell progress-page">
  <FreshnessStatus
    updatedAt={index.updated_at}
    thresholdHours={index.freshness_threshold_hours}
    captureValid={index.sampling?.latest_snapshot_valid ?? true}
  />
  <p class="eyebrow">{days} day ranking · 真实窗口积累中</p>
  <h1>近 {days} 日榜，<br />还差 {Math.max(0, progress.required - progress.completed)} 个有效窗口。</h1>
  <p class="progress-copy">周期榜必须拥有 {days} 个连续、有效的零点快照窗口。如果某日缺失或采样失效，进度会自动延后，不使用部分窗口凑数。</p>
  <div class="progress-meter" aria-label={`已完成 ${progress.completed} / ${progress.required}`}>
    <div><span style={`width:${percentage}%`}></span></div>
    <strong>{progress.completed} / {progress.required}</strong>
  </div>
  <nav class="inline-links" aria-label="相关页面">
    <a class="text-link" href={withBase('/status/')}>查看采样状态 →</a>
    <a class="text-link" href={withBase('/methodology/')}>了解有效窗口 →</a>
  </nav>
</main>
