---
import type { RankingIndex } from '../types';
import { withBase } from '../lib/paths';
import FreshnessStatus from './FreshnessStatus.astro';

interface Props {
  index: RankingIndex;
  days: 7 | 30;
}

const { index, days } = Astro.props;
const progress = index.sampling?.period_progress[`${days}d`] ?? { completed: 0, required: days };
const percentage = Math.min(100, Math.round((progress.completed / progress.required) * 100));
const consecutiveSnapshots = index.sampling?.consecutive_valid_snapshots ?? 0;
const remainingWindows = Math.max(0, progress.required - progress.completed);
const formatDateTime = (value: string | null | undefined) => value
  ? new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(value))
  : '待定';
const expectedAt = (() => {
  const next = index.sampling?.next_scheduled_at;
  if (!next || remainingWindows === 0) return null;
  const value = new Date(next);
  value.setUTCDate(value.getUTCDate() + Math.max(0, remainingWindows - 1));
  return value.toISOString();
})();
---

<main id="main-content" class="shell progress-page">
  <FreshnessStatus
    updatedAt={index.updated_at}
    thresholdHours={index.freshness_threshold_hours}
    captureValid={index.sampling?.latest_snapshot_valid ?? true}
  />
  <p class="eyebrow">{days} day ranking · 每日检查连续窗口</p>
  <h1>近 {days} 日榜正在积累真实窗口。</h1>
  <p class="progress-copy">已经采到 {consecutiveSnapshots} 个连续有效快照，其中形成 {progress.completed} 个完整统计窗口。基线快照本身不代表一天增量，所以“1 个基线、0 个窗口”是正常状态。</p>
  <dl class="progress-summary">
    <div><dt>连续有效快照</dt><dd>{consecutiveSnapshots}</dd><small>第一个只作为基线</small></div>
    <div><dt>已完成窗口</dt><dd>{progress.completed} / {progress.required}</dd><small>还差 {remainingWindows} 个</small></div>
    <div><dt>下次计划采样</dt><dd>{formatDateTime(index.sampling?.next_scheduled_at)}</dd><small>有效窗 00:00–03:00</small></div>
    <div><dt>最早预计发布</dt><dd>{remainingWindows === 0 ? '已具备条件' : formatDateTime(expectedAt)}</dd><small>前提是后续采样连续有效</small></div>
  </dl>
  <div class="progress-meter" aria-label={`已完成 ${progress.completed} / ${progress.required}`}>
    <div><span style={`width:${percentage}%`}></span></div>
    <strong>{progress.completed} / {progress.required}</strong>
  </div>
  <p class="progress-explanation">缺失日期不补零、不插值。如果某次采样超出有效时间或与前一次间隔不符合 21–27 小时，预计日期会自动延后。</p>
  <nav class="inline-links" aria-label="相关页面">
    <a class="text-link" href={withBase('/status/')}>查看采样状态 →</a>
    <a class="text-link" href={withBase('/methodology/')}>了解有效窗口 →</a>
  </nav>
</main>
