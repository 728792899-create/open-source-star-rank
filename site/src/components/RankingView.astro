---
import type {
  DailyRanking, EventDailyRanking, EventRankingEntry, EventRankingIndex, LanguageRanking,
  PeriodRanking, RankingEntry, RankingIndex,
} from '../types';
import { withBase } from '../lib/paths';
import { readClassificationIndex, readClassificationRepositories, readLocalizationCatalog } from '../lib/data';
import { classificationLabels, classificationMap } from '../lib/classification';
import { localizedRepositoryContent } from '../lib/localization';
import FreshnessStatus from './FreshnessStatus.astro';

interface Props {
  ranking: DailyRanking | LanguageRanking | PeriodRanking | EventDailyRanking;
  index: RankingIndex | EventRankingIndex;
  isLatest?: boolean;
  mode?: 'daily' | 'language' | 'period' | 'event';
  availableDates?: string[];
  routePrefix?: string;
  dataPrefix?: string;
  alternateHref?: string;
  alternateLabel?: string;
  fallbackNotice?: string;
  headlineOverride?: string;
  sectionTitleOverride?: string;
  sectionEyebrowOverride?: string;
  rankingPathOverride?: string;
  showDateTools?: boolean;
}

const {
  ranking,
  index,
  isLatest = false,
  mode = 'daily',
  availableDates = index.available_dates,
  routePrefix = '/daily',
  dataPrefix = '/data/daily',
  alternateHref,
  alternateLabel,
  fallbackNotice,
  headlineOverride,
  sectionTitleOverride,
  sectionEyebrowOverride,
  rankingPathOverride,
  showDateTools = true,
} = Astro.props;
const isEvent = mode === 'event' && 'source_metrics' in ranking;
const eventRanking = isEvent ? ranking as EventDailyRanking : null;
const snapshotRanking = !isEvent ? ranking as DailyRanking | LanguageRanking | PeriodRanking : null;
const periodDays = 'period_days' in ranking ? ranking.period_days : null;
const languageName = 'language' in ranking ? ranking.language : null;
const hasRepositoryPages = !isEvent && index.schema_version === '1.2.0';
const defaultHeadline = periodDays
  ? `近 ${periodDays} 日，哪些项目升温最快？`
  : languageName
    ? `${languageName} 项目，昨日谁在升温？`
    : isEvent ? '昨日，全站公开事件中哪些项目获得最多新 Star？' : '昨日，哪些开源项目正在升温？';
const gainLabel = isEvent ? '日新增' : periodDays ? `${periodDays} 日净增` : '日净增';
const heroCopy = isEvent
  ? '扫描 GH Archive 归档的全部 GitHub 公开事件，按为仓库加星的唯一用户数排序；不扣除取消 Star。'
  : '按有效连续快照的 Star 净增排序。缺失日期不补零、不插值，只记录真实发生的关注变化。';
const languages = [...new Set(ranking.entries.map((entry) => entry.language).filter(Boolean) as string[])].sort((a, b) => a.localeCompare(b));
const dateIndex = availableDates.indexOf(ranking.date);
const newer = dateIndex > 0 ? availableDates[dateIndex - 1] : null;
const older = dateIndex >= 0 && dateIndex < availableDates.length - 1 ? availableDates[dateIndex + 1] : null;
const formatNumber = (value: number) => new Intl.NumberFormat('zh-CN').format(value);
const formatCompact = (value: number) => new Intl.NumberFormat('zh-CN', { notation: 'compact', maximumFractionDigits: 1 }).format(value);
const formatDate = (value: string) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${value}T12:00:00+08:00`));
const formatTime = (value: string) => new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(value));
const formatBytes = (value: number) => `${(value / 1024 ** 3).toFixed(2)} GiB`;
const entryGain = (entry: RankingEntry | EventRankingEntry) => 'stars_added' in entry ? entry.stars_added : entry.stars_gained;
const makeTrendShape = (values: Array<number | null>) => {
  const numericValues = values.filter((value): value is number => value !== null);
  const maximum = Math.max(1, ...numericValues.map((value) => Math.abs(value)));
  const points = values.map((value, index) => {
    const x = Math.round((index / Math.max(1, values.length - 1)) * 100);
    const height = value === null ? 5 : Math.max(10, Math.round((Math.abs(value) / maximum) * 100));
    return `${x}% ${100 - height}%`;
  });
  return `polygon(0 100%, ${points.join(', ')}, 100% 100%)`;
};
const rankingPath = withBase(rankingPathOverride ?? `${routePrefix}/${ranking.date}/`);
const rankingJsonPath = withBase(`${dataPrefix}/${ranking.date}.json`);
const localization = readLocalizationCatalog();
const classificationIndex = readClassificationIndex();
const classifications = classificationMap(readClassificationRepositories());
const labels = classificationLabels(classificationIndex);
const usedClassifications = ranking.entries.map((entry) => classifications.get(entry.repository_id)).filter(Boolean);
const usedCategories = classificationIndex.categories.filter((term) => usedClassifications.some((item) => item?.primary_category === term.id));
const usedProjectTypes = classificationIndex.project_types.filter((term) => usedClassifications.some((item) => item?.project_type === term.id));
const usedUseCases = classificationIndex.use_cases.filter((term) => usedClassifications.some((item) => item?.use_cases.includes(term.id)));
const headline = headlineOverride ?? defaultHeadline;
const sectionEyebrow = sectionEyebrowOverride ?? (isEvent ? 'Global public events top 100' : `Observed ${languageName ? 'language top 50' : 'top 100'}`);
const sectionTitle = sectionTitleOverride ?? (isEvent ? '全站公开事件新增 Star 排行' : `${languageName ? `${languageName} ` : ''}${periodDays ? `${periodDays} 日 ` : ''}Star 净增排行`);
const uniqueAdditionCount = eventRanking?.source_metrics.unique_star_addition_count ?? null;
---

<main id="main-content" data-ranking data-ranking-mode={mode} data-daily-path={rankingPath} data-ranking-date={ranking.date} class="shell ranking-page">
  <nav class="ranking-mode-switcher" aria-label="榜单口径">
    <strong>{isEvent ? '全站公开事件新增榜' : '候选池净增榜'}</strong>
    {alternateHref && alternateLabel && <a href={withBase(alternateHref)}>{alternateLabel} →</a>}
  </nav>
  {fallbackNotice && <p class="pipeline-fallback" role="status">{fallbackNotice}</p>}
  <header class="ranking-summary" aria-labelledby="ranking-title">
    <div>
      <p class="eyebrow">{sectionEyebrow} · {formatDate(ranking.date)}</p>
      <h1 id="ranking-title">{sectionTitle}</h1>
      <p class="ranking-summary-copy"><strong>{headline}</strong><span>{heroCopy}</span></p>
    </div>
    <time class="ranking-date-chip" datetime={ranking.date} aria-label={`榜单日期 ${ranking.date}`}>
      <span>{isLatest ? 'LATEST' : 'ARCHIVE'}</span>
      <strong>{ranking.date}</strong>
      <small>UTC+8</small>
    </time>
  </header>

  <FreshnessStatus updatedAt={index.updated_at} thresholdHours={index.freshness_threshold_hours} compact />

  <section class="metrics" aria-label="榜单统计">
    <div><span>{isEvent ? '全站事件仓库' : '候选池'}</span><strong>{formatNumber(eventRanking?.source_metrics.observed_repository_count ?? snapshotRanking?.candidate_count ?? 0)}</strong><small>{isEvent ? '个仓库获得公开 Star 事件' : '个公开仓库'}</small></div>
    <div><span>{isEvent ? '唯一新增' : '可比较'}</span><strong>{isEvent ? uniqueAdditionCount === null ? '—' : formatNumber(uniqueAdditionCount) : formatNumber(ranking.eligible_count)}</strong><small>{isEvent ? uniqueAdditionCount === null ? '旧版数据未汇总' : '用户—仓库唯一对' : '拥有连续快照'}</small></div>
    <div><span>上榜项目</span><strong>{ranking.entries.length}</strong><small>{isEvent ? '按新增排序' : '按净增排序'}</small></div>
    <div><span>采样窗口</span><strong>{formatTime(ranking.window_start)}</strong><small>至 {formatTime(ranking.window_end)}</small></div>
  </section>

  {isEvent ? <details class="collection-details">
    <summary>查看数据详情：GH Archive、覆盖与费用保护</summary>
    <dl>
      <div><dt>WatchEvent</dt><dd>{formatNumber(eventRanking!.source_metrics.observed_watch_event_count)}</dd></div>
      <div><dt>唯一新增</dt><dd>{uniqueAdditionCount === null ? '旧版未记录' : formatNumber(uniqueAdditionCount)}</dd></div>
      <div><dt>24 小时覆盖</dt><dd>{eventRanking!.source_metrics.observed_hour_count === undefined ? '旧版未记录' : `${eventRanking!.source_metrics.observed_hour_count} / ${eventRanking!.source_metrics.expected_hour_count} 小时`}</dd></div>
      <div><dt>排行完整性</dt><dd>{eventRanking!.source_metrics.ranking_complete ? '已验证 Top 100' : '旧版规则'}</dd></div>
      <div><dt>BigQuery 扫描</dt><dd>{formatBytes(eventRanking!.source_metrics.bytes_processed)}</dd></div>
      <div><dt>扫描硬上限</dt><dd>{formatBytes(eventRanking!.source_metrics.maximum_bytes_billed)}</dd></div>
      <div><dt>源表</dt><dd>{eventRanking!.source_metrics.table_dates.join(' / ')}</dd></div>
      <div><dt>元数据成功</dt><dd>{formatNumber(eventRanking!.source_metrics.metadata_success_count)}</dd></div>
      <div><dt>404 / 过滤</dt><dd>{eventRanking!.source_metrics.metadata_not_found_count} / {eventRanking!.source_metrics.metadata_filtered_count}</dd></div>
      <div><dt>API 请求 / 重试</dt><dd>{eventRanking!.source_metrics.api_request_count} / {eventRanking!.source_metrics.api_retry_count}</dd></div>
      <div><dt>数据范围</dt><dd>GH Archive 归档的 GitHub 公开事件</dd></div>
    </dl>
  </details> : <details class="collection-details">
    <summary>查看数据详情：搜索覆盖、API 与快照完整性</summary>
    <dl>
      <div><dt>最近创建搜索</dt><dd>{formatNumber(snapshotRanking!.collection.search_result_counts.recent_created)}</dd></div>
      <div><dt>近期活跃搜索</dt><dd>{formatNumber(snapshotRanking!.collection.search_result_counts.recent_active)}</dd></div>
      <div><dt>成熟项目搜索</dt><dd>{formatNumber(snapshotRanking!.collection.search_result_counts.established_active)}</dd></div>
      <div><dt>去重新发现</dt><dd>{formatNumber(snapshotRanking!.collection.unique_discovered_count)}</dd></div>
      <div><dt>候选进 / 出</dt><dd>+{formatNumber(snapshotRanking!.collection.candidate_added_count)} / −{formatNumber(snapshotRanking!.collection.candidate_removed_count)}</dd></div>
      <div><dt>API 请求 / 重试</dt><dd>{formatNumber(snapshotRanking!.collection.api_request_count)} / {formatNumber(snapshotRanking!.collection.api_retry_count)}</dd></div>
      <div><dt>快照完整率</dt><dd>{(snapshotRanking!.collection.snapshot_completeness * 100).toFixed(1)}%</dd></div>
    </dl>
  </details>}

  <section class="ranking-section" aria-labelledby="ranking-title">
    <div class="ranking-toolbar">
      <div class="ranking-actions" aria-label="榜单操作">
        <button type="button" data-copy-ranking>复制榜单链接</button>
        <a href={rankingJsonPath} download>下载当日 JSON</a>
        <span class="action-status" data-action-status aria-live="polite"></span>
      </div>
      {showDateTools && <div class="date-tools">
        <label class="date-picker">
          <span>历史日期</span>
          <select data-date-selector aria-label="选择历史榜单日期">
            {availableDates.map((date) => <option value={withBase(`${routePrefix}/${date}/`)} selected={date === ranking.date}>{date}</option>)}
          </select>
        </label>
        <div class="date-nav" aria-label="历史榜单日期">
          {older ? <a href={withBase(`${routePrefix}/${older}/`)} aria-label={`查看 ${older} 榜单`}>← 前一日</a> : <span>← 前一日</span>}
          {newer ? <a href={withBase(`${routePrefix}/${newer}/`)} aria-label={`查看 ${newer} 榜单`}>后一日 →</a> : <span>后一日 →</span>}
        </div>
      </div>}
    </div>

    <div class="filters" role="search">
      <label class="filter-search">
        <span>搜索项目</span>
        <input data-search type="search" placeholder="仓库名或描述" autocomplete="off" />
      </label>
      <details class="advanced-filters" data-advanced-filters open>
        <summary>更多筛选 <span data-advanced-filter-summary>未启用</span></summary>
        <div class="advanced-filter-grid">
          <label>
            <span>编程语言</span>
            <select data-language>
              <option value="">全部语言</option>
              {languages.map((language) => <option value={language}>{language}</option>)}
            </select>
          </label>
          <label>
            <span>项目方向</span>
            <select data-category>
              <option value="">全部方向</option>
              {usedCategories.map((term) => <option value={term.id}>{term.label}</option>)}
            </select>
          </label>
          <label>
            <span>产品形态</span>
            <select data-project-type>
              <option value="">全部形态</option>
              {usedProjectTypes.map((term) => <option value={term.id}>{term.label}</option>)}
            </select>
          </label>
          <label>
            <span>适用场景</span>
            <select data-scenario>
              <option value="">全部场景</option>
              {usedUseCases.map((term) => <option value={term.id}>{term.label}</option>)}
            </select>
          </label>
        </div>
      </details>
      <p class="filter-count" aria-live="polite"><strong data-visible-count>{ranking.entries.length}</strong> / {ranking.entries.length} 个项目</p>
    </div>
    <script is:inline>
      (() => {
        if (!window.matchMedia('(max-width: 680px)').matches) return;
        const parameters = new URLSearchParams(window.location.search);
        const hasAdvancedSelection = ['language', 'category', 'type', 'scenario'].some((name) => parameters.has(name));
        if (hasAdvancedSelection) return;
        const script = document.currentScript;
        const filters = script?.previousElementSibling;
        filters?.querySelector('[data-advanced-filters]')?.removeAttribute('open');
      })();
    </script>

    <div class="ranking-table" role="table" aria-label={`${ranking.date} Star ${isEvent ? '新增' : '净增'}排行`}>
      <div class="table-head" role="row">
        <span role="columnheader">排名 / 变化</span>
        <span role="columnheader">项目</span>
        <span role="columnheader">语言</span>
        <span role="columnheader">7 日趋势</span>
        <span role="columnheader">总 Star / {gainLabel}</span>
      </div>
      <div class="table-body">
        {ranking.entries.map((entry) => {
          const gained = entryGain(entry);
          const trendShape = makeTrendShape(entry.trend_7d);
          const content = localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description);
          const classification = classifications.get(entry.repository_id);
          const categoryLabel = classification ? labels.categories.get(classification.primary_category) : null;
          const projectTypeLabel = classification ? labels.projectTypes.get(classification.project_type) : null;
          const useCaseLabels = classification?.use_cases.map((id) => labels.useCases.get(id)).filter(Boolean) as string[] | undefined;
          const searchText = `${entry.full_name} ${entry.description ?? ''} ${content.displayName} ${content.description ?? ''} ${categoryLabel ?? ''} ${projectTypeLabel ?? ''} ${useCaseLabels?.join(' ') ?? ''}`;
          const movement = entry.rank_change === null ? '新上榜' : entry.rank_change > 0 ? `↑${entry.rank_change}` : entry.rank_change < 0 ? `↓${Math.abs(entry.rank_change)}` : '—';
          const movementClass = entry.rank_change === null ? 'new' : entry.rank_change > 0 ? 'up' : entry.rank_change < 0 ? 'down' : 'flat';
          return (
            <div
              id={`repo-${entry.repository_id}`}
              class="ranking-row"
              role="row"
              data-ranking-row
              data-search-text={searchText.toLocaleLowerCase()}
              data-language={entry.language ?? ''}
              data-category={classification?.primary_category ?? ''}
              data-project-type={classification?.project_type ?? ''}
              data-scenarios={classification?.use_cases.join(',') ?? ''}
            >
              <strong
                class:list={['rank-cell', movementClass]}
                role="cell"
                data-movement={movement}
                aria-label={`排名 ${entry.rank}，变化 ${movement}`}
              >{String(entry.rank).padStart(2, '0')}</strong>
              <div class="project-cell" role="cell">
                <div class="project-copy">
                  {content.localized ? <>
                    <a class="project-link" data-content-language="zh" href={hasRepositoryPages ? withBase(`/repo/${entry.repository_id}/`) : entry.html_url} target={hasRepositoryPages ? undefined : '_blank'} rel={hasRepositoryPages ? undefined : 'noreferrer'}>{content.displayName}</a>
                    <a class="project-link" data-content-language="original" href={hasRepositoryPages ? withBase(`/repo/${entry.repository_id}/`) : entry.html_url} target={hasRepositoryPages ? undefined : '_blank'} rel={hasRepositoryPages ? undefined : 'noreferrer'}>{entry.full_name}</a>
                    <span class="project-source-row" data-content-language="zh">
                      <span class="project-source-name">{entry.full_name}</span>
                      <span class="translation-badge" title={content.provenance === 'manual' ? '人工校订中文内容' : 'GitHub Models 生成的中文内容'}>{content.provenance === 'manual' ? '人工校订' : 'AI 译'}</span>
                    </span>
                    <p>
                      <span data-content-language="zh">{content.description || 'GitHub 未提供项目描述。'}</span>
                      <span data-content-language="original">{entry.description || 'No description provided.'}</span>
                    </p>
                  </> : <>
                    <a class="project-link" href={hasRepositoryPages ? withBase(`/repo/${entry.repository_id}/`) : entry.html_url} target={hasRepositoryPages ? undefined : '_blank'} rel={hasRepositoryPages ? undefined : 'noreferrer'}>{entry.full_name}</a>
                    <span class="project-source-row"><span class="translation-pending">中文待生成</span></span>
                    <p>{entry.description || 'No description provided.'}</p>
                  </>}
                  {classification ? <div class="classification-tags" aria-label="项目分类">
                    <a href={withBase(`/category/${classification.primary_category}/`)}>{categoryLabel}</a>
                    <span>{projectTypeLabel}</span>
                    {useCaseLabels?.slice(0, 2).map((label) => <span>{label}</span>)}
                  </div> : <span class="classification-pending">分类待生成</span>}
                </div>
                {hasRepositoryPages && <a class="github-link" href={entry.html_url} target="_blank" rel="noreferrer" aria-label={`在 GitHub 打开 ${entry.full_name}`}>GitHub ↗</a>}
                <button
                  class="share-project"
                  type="button"
                  data-share-project
                  data-share-name-zh={content.displayName}
                  data-share-name-original={entry.full_name}
                  data-share-rank={entry.rank}
                  aria-label={`分享 ${entry.full_name} 的第 ${entry.rank} 名`}
                >分享</button>
              </div>
              <div class="language-cell" role="cell">{entry.language || 'Other'}</div>
              <div
                class="trend-cell"
                role="cell"
                aria-label={`最近七日${isEvent ? '新增' : '净增'}：${entry.trend_7d.map((value) => value ?? '无数据').join('、')}`}
                style={`--trend-shape:${trendShape}`}
              ></div>
              <div class:list={['stars-cell', 'numeric', { negative: gained < 0 }]} role="cell" data-mobile-label={`总 Star / ${gainLabel}`}>
                {formatCompact(entry.stars_total)} · {gained >= 0 ? '+' : ''}{formatNumber(gained)}
              </div>
            </div>
          );
        })}
      </div>
    </div>
    <div class="empty-state" data-empty-state hidden>
      <strong>没有匹配的项目</strong>
      <p>试试缩短关键词，或切换到全部语言。</p>
    </div>
  </section>

  <aside class="method-note" aria-label="榜单口径提示">
    <span aria-hidden="true">i</span>
    <p><strong>这是一张观测榜。</strong>{isEvent ? '“全站”限定为 GH Archive 实际归档的 GitHub 公开事件范围；数字表示每个仓库的唯一新增加星用户，不包含私有活动或取消 Star，不是 GitHub 官方统计。' : 'GitHub 搜索不支持按每日增量检索全站项目，因此净增榜来自持续追踪的候选池；新项目获得两个快照后才参与排名。'}</p>
    <a href={withBase('/methodology/')}>完整口径 →</a>
  </aside>
</main>

<script>
  import { matchesEntry } from '../scripts/filter-utils.mjs';

  const root = document.querySelector('[data-ranking]');
  if (root) {
    const initializeRanking = () => {
      if (!(root instanceof HTMLElement) || root.dataset.rankingEnhanced === 'true') return;
      root.dataset.rankingEnhanced = 'true';
    const search = root.querySelector('[data-search]');
    const language = root.querySelector('[data-language]');
    const category = root.querySelector('[data-category]');
    const projectType = root.querySelector('[data-project-type]');
    const scenario = root.querySelector('[data-scenario]');
    const advancedFilters = root.querySelector('[data-advanced-filters]');
    const advancedFilterSummary = root.querySelector('[data-advanced-filter-summary]');
    const visibleCount = root.querySelector('[data-visible-count]');
    const emptyState = root.querySelector('[data-empty-state]');
    const actionStatus = root.querySelector('[data-action-status]');
    const dailyPath = root.getAttribute('data-daily-path') ?? window.location.pathname;
    const rankingDate = root.getAttribute('data-ranking-date') ?? '';
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') ?? '';
    const initialLanguage = params.get('language') ?? '';
    const initialCategory = params.get('category') ?? '';
    const initialProjectType = params.get('type') ?? '';
    const initialScenario = params.get('scenario') ?? '';
    if (search instanceof HTMLInputElement && initialQuery) search.value = initialQuery;
    if (language instanceof HTMLSelectElement && initialLanguage) language.value = initialLanguage;
    if (category instanceof HTMLSelectElement && initialCategory) category.value = initialCategory;
    if (projectType instanceof HTMLSelectElement && initialProjectType) projectType.value = initialProjectType;
    if (scenario instanceof HTMLSelectElement && initialScenario) scenario.value = initialScenario;
    const initialAdvancedCount = [initialLanguage, initialCategory, initialProjectType, initialScenario].filter(Boolean).length;
    if (advancedFilters instanceof HTMLDetailsElement && initialAdvancedCount > 0) advancedFilters.open = true;

    const apply = () => {
      const query = search instanceof HTMLInputElement ? search.value : '';
      const selectedLanguage = language instanceof HTMLSelectElement ? language.value : '';
      const selectedCategory = category instanceof HTMLSelectElement ? category.value : '';
      const selectedProjectType = projectType instanceof HTMLSelectElement ? projectType.value : '';
      const selectedScenario = scenario instanceof HTMLSelectElement ? scenario.value : '';
      const activeAdvancedCount = [selectedLanguage, selectedCategory, selectedProjectType, selectedScenario].filter(Boolean).length;
      let count = 0;
      for (const row of root.querySelectorAll('[data-ranking-row]')) {
        if (!(row instanceof HTMLElement)) continue;
        const visible = matchesEntry(
          {
            searchText: row.dataset.searchText ?? '', language: row.dataset.language ?? '',
            category: row.dataset.category ?? '', projectType: row.dataset.projectType ?? '',
            scenarios: (row.dataset.scenarios ?? '').split(',').filter(Boolean),
          },
          query,
          selectedLanguage,
          selectedCategory,
          selectedProjectType,
          selectedScenario,
        );
        row.hidden = !visible;
        if (visible) count += 1;
      }
      if (visibleCount) visibleCount.textContent = String(count);
      if (advancedFilterSummary) {
        advancedFilterSummary.textContent = activeAdvancedCount > 0 ? `${activeAdvancedCount} 项已启用` : '未启用';
      }
      if (emptyState instanceof HTMLElement) emptyState.hidden = count !== 0;
      const next = new URL(window.location.href);
      query.trim() ? next.searchParams.set('q', query.trim()) : next.searchParams.delete('q');
      selectedLanguage ? next.searchParams.set('language', selectedLanguage) : next.searchParams.delete('language');
      selectedCategory ? next.searchParams.set('category', selectedCategory) : next.searchParams.delete('category');
      selectedProjectType ? next.searchParams.set('type', selectedProjectType) : next.searchParams.delete('type');
      selectedScenario ? next.searchParams.set('scenario', selectedScenario) : next.searchParams.delete('scenario');
      window.history.replaceState({}, '', next);
    };
    search?.addEventListener('input', apply);
    language?.addEventListener('change', apply);
    category?.addEventListener('change', apply);
    projectType?.addEventListener('change', apply);
    scenario?.addEventListener('change', apply);

    const copyText = async (value: string) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }
      throw new Error('Clipboard API unavailable');
    };
    const setStatus = (message: string) => {
      if (actionStatus) actionStatus.textContent = message;
    };
    const rankingUrl = () => {
      const url = new URL(dailyPath, window.location.origin);
      if (document.documentElement.dataset.projectLanguage === 'original') url.searchParams.set('display', 'original');
      return url.toString();
    };
    root.addEventListener('click', async (event) => {
      if (!(event.target instanceof Element)) return;
      if (event.target.closest('[data-copy-ranking]')) {
        try {
          await copyText(rankingUrl());
          setStatus('榜单链接已复制');
        } catch {
          setStatus('复制失败，请从地址栏复制');
        }
        return;
      }
      const button = event.target.closest('[data-share-project]');
      if (button instanceof HTMLButtonElement) {
        const name = document.documentElement.dataset.projectLanguage === 'original'
          ? button.dataset.shareNameOriginal ?? 'GitHub 项目'
          : button.dataset.shareNameZh ?? button.dataset.shareNameOriginal ?? 'GitHub 项目';
        const rank = button.dataset.shareRank ?? '';
        const row = button.closest('[data-ranking-row]');
        const url = `${rankingUrl()}#${row?.id ?? ''}`;
        const shareData = {
          title: `${name}｜开源星榜第 ${rank} 名`,
          text: `${name} 在 ${rankingDate} 开源星榜位列第 ${rank} 名。`,
          url,
        };
        try {
          if (navigator.share) {
            await navigator.share(shareData);
            setStatus('分享面板已打开');
          } else {
            await copyText(url);
            setStatus(`${name} 的排名链接已复制`);
          }
        } catch (error) {
          if (error instanceof DOMException && error.name === 'AbortError') return;
          try {
            await copyText(url);
            setStatus(`${name} 的排名链接已复制`);
          } catch {
            setStatus('分享失败，请稍后重试');
          }
        }
      }
    });
    apply();
    };
    root.addEventListener('change', (event) => {
      if (event.target instanceof HTMLSelectElement && event.target.matches('[data-date-selector]') && event.target.value) {
        window.location.assign(event.target.value);
      }
    });
    for (const eventName of ['focusin', 'pointerdown', 'keydown', 'change']) {
      root.addEventListener(eventName, initializeRanking, { capture: true, once: true });
    }
    if (window.location.search) initializeRanking();
  }
</script>
