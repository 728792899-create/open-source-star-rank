---
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown>;
  socialImagePath?: string;
  robots?: string;
  prevPath?: string;
  nextPath?: string;
}

const {
  title = '开源星榜｜GitHub 全站公开事件新增与候选池净增排行',
  description = '每日汇总 GH Archive 归档的 GitHub 全站公开 WatchEvent 新增 Star 信号，并保留候选池连续快照净增榜。',
  structuredData,
  socialImagePath = '/og.png',
  robots = 'index,follow',
  prevPath,
  nextPath,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const socialImage = new URL(withBase(socialImagePath), Astro.site ?? Astro.url.origin).toString();
const repositoryUrl = 'https://github.com/728792899-create/open-source-star-rank';
const reuseStatementUrl = `${repositoryUrl}/blob/main/REUSE.md`;
const authApiUrl = import.meta.env.PUBLIC_AUTH_API_URL?.replace(/\/$/u, '') ?? '';
---

<!doctype html>
<html lang="zh-CN" data-auth-api-url={authApiUrl}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f3efe4" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='16' fill='%23171814'/%3E%3Cpath d='m16 5 3.1 6.3 6.9 1-5 4.8 1.2 6.9-6.2-3.2L9.8 24l1.2-6.9-5-4.8 6.9-1z' fill='%23f2dcae'/%3E%3C/svg%3E" />
    <link rel="canonical" href={canonical} />
    {prevPath && <link rel="prev" href={new URL(withBase(prevPath), Astro.site ?? Astro.url.origin).toString()} />}
    {nextPath && <link rel="next" href={new URL(withBase(nextPath), Astro.site ?? Astro.url.origin).toString()} />}
    <link rel="alternate" type="application/rss+xml" title="开源星榜每日排行" href={new URL(withBase('/rss.xml'), Astro.site ?? Astro.url.origin).toString()} />
    <link rel="alternate" type="application/atom+xml" title="开源星榜 Atom" href={new URL(withBase('/atom.xml'), Astro.site ?? Astro.url.origin).toString()} />
    <link rel="alternate" type="application/feed+json" title="开源星榜 JSON Feed" href={new URL(withBase('/feed.json'), Astro.site ?? Astro.url.origin).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const parameter = new URLSearchParams(window.location.search).get('display');
        let stored = null;
        try { stored = window.localStorage.getItem('star-rank-project-language'); } catch {}
        const language = parameter === 'original' || parameter === 'zh'
          ? parameter
          : stored === 'original' ? 'original' : 'zh';
        document.documentElement.dataset.projectLanguage = language;
        let density = null;
        try { density = window.localStorage.getItem('star-rank-density'); } catch {}
        document.documentElement.dataset.rankingDensity = density === 'comfortable' || density === 'compact'
          ? density
          : window.matchMedia('(max-width: 680px)').matches ? 'compact' : 'comfortable';
      })();
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData ?? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: '开源星榜',
      url: new URL(withBase('/'), Astro.site ?? Astro.url.origin).toString(),
      description,
      inLanguage: 'zh-CN',
      sameAs: [repositoryUrl],
    })} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <header class="site-header">
      <a class="brand" href={withBase('/')} aria-label="开源星榜首页">
        <span class="brand-mark" aria-hidden="true">★</span>
        <span>开源星榜</span>
      </a>
      <nav aria-label="主导航">
        <a href={withBase('/')}>昨日净增</a>
        <a href={withBase('/daily/')}>每日净增</a>
        <a href={withBase('/period/7d/')}>7 日榜</a>
        <a href={withBase('/period/30d/')}>30 日榜</a>
        <a href={withBase('/all-time/')}>历史榜</a>
        <details class="nav-data-menu">
          <summary>数据</summary>
          <div>
            <a href={withBase('/status/')}>运行状态</a>
            <a href={withBase('/methodology/')}>数据口径</a>
            <a href={withBase('/language/')}>语言索引</a>
            <a href={withBase('/data/index.json')}>公开 JSON</a>
            <a href={withBase('/rss.xml')}>订阅 RSS</a>
          </div>
        </details>
        <a href={repositoryUrl} target="_blank" rel="noreferrer">GitHub ↗</a>
      </nav>
      <details class="user-library" data-user-library>
        <summary>我的项目 <span data-library-count>0</span></summary>
        <div class="user-library-panel">
          <section>
            <h2>收藏</h2>
            <div data-favorite-list><p>尚未收藏项目。</p></div>
            <button class="library-sync" type="button" data-sync-favorites hidden>同步到 GitHub</button>
            <p data-sync-status aria-live="polite"></p>
          </section>
          <section><h2>对比</h2><div data-compare-list><p>最多选择 4 个项目。</p></div><a class="text-link" href={withBase('/compare/')}>打开对比页 →</a></section>
          <section><h2>最近查看</h2><div data-recent-list><p>暂无记录。</p></div></section>
        </div>
      </details>
      <div class="github-auth" data-github-auth>
        <button type="button" data-github-login>GitHub 登录</button>
        <div data-github-user hidden>
          <img data-github-avatar alt="" width="22" height="22" />
          <span data-github-login-name></span>
          <button type="button" data-github-logout>退出</button>
        </div>
      </div>
      <div class="content-language-switcher" role="group" aria-label="项目内容显示语言">
        <span>项目内容</span>
        <button type="button" data-project-language="zh" aria-pressed="true">中文</button>
        <button type="button" data-project-language="original" aria-pressed="false">原文</button>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="site-footer-copy">
        <p><strong>开源星榜</strong>的“全站”限定为 GH Archive 实际归档的 GitHub 公开事件，不是 GitHub 官方统计。</p>
        <p>数据来自 GH Archive 与 GitHub 公共 API · 事件榜每小时更新，候选池日榜每日零点更新</p>
      </div>
      <nav class="site-footer-links" aria-label="项目源码与复用">
        <a href={withBase('/rss.xml')}>每日订阅 RSS</a>
        <a href={repositoryUrl} target="_blank" rel="noreferrer">GitHub 仓库 ↗</a>
        <a href={reuseStatementUrl} target="_blank" rel="noreferrer">复用声明 ↗</a>
      </nav>
    </footer>
    <aside class="compare-tray" data-compare-tray hidden>
      <strong><span data-compare-count>0</span> / 4 个项目待对比</strong>
      <a href={withBase('/compare/')}>查看对比 →</a>
    </aside>
    <button class="back-to-top" type="button" data-back-to-top hidden aria-label="返回顶部">↑</button>
    <dialog class="auth-choice" data-auth-choice aria-labelledby="auth-choice-title">
      <form method="dialog">
        <h2 id="auth-choice-title">收藏这个项目</h2>
        <p>登录后，“收藏”会直接同步为你的 GitHub Star；也可以只保存在当前浏览器。</p>
        <div>
          <button type="button" value="github" data-auth-choice-github>使用 GitHub 登录并同步</button>
          <button type="button" value="local" data-auth-choice-local>仅保存在本机</button>
          <button type="button" value="cancel" data-auth-choice-cancel>取消</button>
        </div>
        <small data-auth-choice-note></small>
      </form>
    </dialog>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const buttons = Array.from(document.querySelectorAll('.content-language-switcher [data-project-language]'));
        const updateButtons = () => {
          const active = root.dataset.projectLanguage === 'original' ? 'original' : 'zh';
          for (const button of buttons) {
            button.setAttribute('aria-pressed', String(button.getAttribute('data-project-language') === active));
          }
        };
        const setLanguage = (language) => {
          const nextLanguage = language === 'original' ? 'original' : 'zh';
          root.dataset.projectLanguage = nextLanguage;
          try { window.localStorage.setItem('star-rank-project-language', nextLanguage); } catch {}
          const next = new URL(window.location.href);
          nextLanguage === 'original'
            ? next.searchParams.set('display', 'original')
            : next.searchParams.delete('display');
          window.history.replaceState({}, '', next);
          updateButtons();
          window.dispatchEvent(new CustomEvent('projectlanguagechange', { detail: { language: nextLanguage } }));
        };
        for (const button of buttons) {
          button.addEventListener('click', () => setLanguage(button.getAttribute('data-project-language')));
        }
        updateButtons();
      })();
    </script>
    <script is:inline>
      (() => {
        const storageKey = 'star-rank-user-library-v1';
        const empty = () => ({ favorites: [], compare: [], recent: [] });
        const read = () => {
          try {
            const parsed = JSON.parse(window.localStorage.getItem(storageKey) || 'null');
            return parsed && Array.isArray(parsed.favorites) && Array.isArray(parsed.compare) && Array.isArray(parsed.recent) ? parsed : empty();
          } catch { return empty(); }
        };
        const write = (library) => {
          try { window.localStorage.setItem(storageKey, JSON.stringify(library)); } catch {}
          window.dispatchEvent(new CustomEvent('starranklibrarychange', { detail: library }));
        };
        window.starRankLibrary = { read, write };
        const item = (project) => {
          const link = document.createElement('a');
          link.href = project.url;
          link.textContent = project.name;
          const row = document.createElement('div');
          row.append(link);
          return row;
        };
        const renderList = (target, projects, emptyText) => {
          if (!(target instanceof HTMLElement)) return;
          target.replaceChildren();
          if (!projects.length) {
            const copy = document.createElement('p');
            copy.textContent = emptyText;
            target.append(copy);
            return;
          }
          for (const project of projects) target.append(item(project));
        };
        const render = () => {
          const library = read();
          renderList(document.querySelector('[data-favorite-list]'), library.favorites, '尚未收藏项目。');
          renderList(document.querySelector('[data-compare-list]'), library.compare, '最多选择 4 个项目。');
          renderList(document.querySelector('[data-recent-list]'), library.recent, '暂无记录。');
          const total = new Set([...library.favorites, ...library.compare].map((project) => project.id)).size;
          const libraryCount = document.querySelector('[data-library-count]');
          if (libraryCount) libraryCount.textContent = String(total);
          const compareCount = document.querySelector('[data-compare-count]');
          if (compareCount) compareCount.textContent = String(library.compare.length);
          const tray = document.querySelector('[data-compare-tray]');
          if (tray instanceof HTMLElement) tray.hidden = library.compare.length < 2;
        };
        window.addEventListener('starranklibrarychange', render);
        render();

        const top = document.querySelector('[data-back-to-top]');
        const updateTop = () => { if (top instanceof HTMLElement) top.hidden = window.scrollY < 900; };
        top?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        window.addEventListener('scroll', updateTop, { passive: true });
        updateTop();

        document.addEventListener('click', (event) => {
          const toggle = event.target instanceof Element ? event.target.closest('[data-density-toggle]') : null;
          if (!(toggle instanceof HTMLButtonElement)) return;
          const current = document.documentElement.dataset.rankingDensity === 'compact' ? 'compact' : 'comfortable';
          const next = current === 'compact' ? 'comfortable' : 'compact';
          document.documentElement.dataset.rankingDensity = next;
          try { window.localStorage.setItem('star-rank-density', next); } catch {}
          document.querySelectorAll('[data-density-toggle]').forEach((button) => {
            button.textContent = next === 'compact' ? '详细模式' : '紧凑模式';
            button.setAttribute('aria-pressed', String(next === 'compact'));
          });
        });
        document.querySelectorAll('[data-density-toggle]').forEach((button) => {
          const compact = document.documentElement.dataset.rankingDensity === 'compact';
          button.textContent = compact ? '详细模式' : '紧凑模式';
          button.setAttribute('aria-pressed', String(compact));
        });
      })();
    </script>
    <script>
      import '../scripts/github-auth.ts';
    </script>
  </body>
</html>
