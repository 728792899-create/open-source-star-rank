---
import type { GetStaticPaths } from 'astro';
import RankingView from '../../../components/RankingView.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  readEventCategoryPool, readEventDailyRanking, readEventRankingIndex, readLocalizationCatalog, readRankingIndex,
} from '../../../lib/data';
import { localizedRepositoryContent } from '../../../lib/localization';
import { withBase } from '../../../lib/paths';

export const getStaticPaths = (() => {
  const index = readEventRankingIndex();
  return index.available_dates.map((date) => ({ params: { date } }));
}) satisfies GetStaticPaths;

const { date } = Astro.params;
if (!date) throw new Error('Missing public event ranking date');
const index = readEventRankingIndex();
const candidateIndex = readRankingIndex();
const ranking = readEventDailyRanking(date);
const exploration = readEventCategoryPool(ranking.date);
const previousDate = new Date(`${ranking.date}T12:00:00Z`);
previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate.toISOString().slice(0, 10);
const previousExploration = readEventCategoryPool(previousDateValue);
const localization = readLocalizationCatalog();
const title = `${ranking.date} GitHub 全站公开事件新增 Star 榜｜开源星榜`;
const description = `${ranking.date} GH Archive 归档的 GitHub 全站公开 WatchEvent 新增 Star Top ${ranking.entries.length}，观察 ${ranking.source_metrics.observed_repository_count} 个获星仓库。`;
const firstPageEntries = ranking.entries.slice(0, 100);
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `${ranking.date} GitHub 全站公开事件新增 Star 排行`,
  numberOfItems: firstPageEntries.length,
  itemListElement: firstPageEntries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank, url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
const sameDateCandidateAvailable = candidateIndex.available_dates.includes(ranking.date);
const alternateCandidateDate = sameDateCandidateAvailable ? ranking.date : candidateIndex.latest_date;
const alternateLabel = sameDateCandidateAvailable ? '查看同日候选池净增榜' : '查看最新候选池净增榜';
---

<BaseLayout title={title} description={description} structuredData={structuredData} socialImagePath={`/social/events-daily-${ranking.date}.png`} nextPath={ranking.entries.length > 100 ? `/events/daily/${ranking.date}/page/2/` : undefined}>
  <RankingView
    ranking={ranking}
    index={index}
    isLatest={ranking.date === index.latest_date}
    mode="event"
    availableDates={index.available_dates}
    routePrefix="/events/daily"
    dataPrefix="/data/events/daily"
    alternateHref={alternateCandidateDate ? `/daily/${alternateCandidateDate}/` : undefined}
    alternateLabel={alternateLabel}
    explorationPath={exploration ? `/data/events/category/${ranking.date}.json` : undefined}
    previousExplorationPath={previousExploration ? `/data/events/category/${previousDateValue}.json` : undefined}
    explorationEntries={exploration?.entries ?? []}
    pageBasePath={`/events/daily/${ranking.date}/`}
    sectionTitleOverride="完整新增 Star 排行"
  />
</BaseLayout>
