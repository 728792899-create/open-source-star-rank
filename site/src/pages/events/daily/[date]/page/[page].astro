---
import type { GetStaticPaths } from 'astro';
import RankingView from '../../../../../components/RankingView.astro';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import {
  readEventCategoryPool, readEventDailyRanking, readEventRankingIndex, readLocalizationCatalog, readRankingIndex,
} from '../../../../../lib/data';
import { localizedRepositoryContent } from '../../../../../lib/localization';
import { withBase } from '../../../../../lib/paths';

export const getStaticPaths = (() => {
  const index = readEventRankingIndex();
  return index.available_dates.flatMap((date) => {
    const ranking = readEventDailyRanking(date);
    const pages = Math.ceil(ranking.entries.length / 100);
    return Array.from({ length: Math.max(0, pages - 1) }, (_, offset) => ({
      params: { date, page: String(offset + 2) }, props: { date, page: offset + 2 },
    }));
  });
}) satisfies GetStaticPaths;

const { date, page } = Astro.props;
const index = readEventRankingIndex();
const candidateIndex = readRankingIndex();
const ranking = readEventDailyRanking(date);
const exploration = readEventCategoryPool(date);
const previousDate = new Date(`${date}T12:00:00Z`);
previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate.toISOString().slice(0, 10);
const previousExploration = readEventCategoryPool(previousDateValue);
const localization = readLocalizationCatalog();
const entries = ranking.entries.slice((page - 1) * 100, page * 100);
const totalPages = Math.ceil(ranking.entries.length / 100);
const basePath = `/events/daily/${date}/`;
const href = (target: number) => target === 1 ? basePath : `${basePath}page/${target}/`;
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `${date} GitHub 全站公开事件新增 Star 排行第 ${page} 页`, numberOfItems: entries.length,
  itemListElement: entries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank,
    url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
const alternateDate = candidateIndex.available_dates.includes(date) ? date : candidateIndex.latest_date;
---

<BaseLayout
  title={`${date} GitHub 全站公开事件新增 Star 榜 ${page}/${totalPages}｜开源星榜`}
  description={`${date} GH Archive 公开新增 Star Top 500 第 ${page} 页，展示第 ${entries[0]?.rank ?? 0}–${entries.at(-1)?.rank ?? 0} 名。`}
  structuredData={structuredData}
  socialImagePath={`/social/events-daily-${date}.png`}
  prevPath={href(page - 1)}
  nextPath={page < totalPages ? href(page + 1) : undefined}
>
  <RankingView
    ranking={ranking} index={index} isLatest={date === index.latest_date} mode="event"
    availableDates={index.available_dates} routePrefix="/events/daily" dataPrefix="/data/events/daily"
    alternateHref={alternateDate ? `/daily/${alternateDate}/` : undefined} alternateLabel="查看候选池净增榜"
    explorationPath={exploration ? `/data/events/category/${date}.json` : undefined}
    previousExplorationPath={previousExploration ? `/data/events/category/${previousDateValue}.json` : undefined}
    explorationEntries={exploration?.entries ?? []} page={page} pageBasePath={basePath}
    sectionTitleOverride="完整新增 Star 排行"
  />
</BaseLayout>
