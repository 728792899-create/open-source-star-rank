---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import RankingView from '../../../../components/RankingView.astro';
import { readEventLiveRanking, readEventRankingIndex, readLocalizationCatalog } from '../../../../lib/data';
import { localizedRepositoryContent } from '../../../../lib/localization';
import { withBase } from '../../../../lib/paths';

export const getStaticPaths = (() => {
  const ranking = readEventLiveRanking();
  if (!ranking) return [];
  const pages = Math.ceil(ranking.entries.length / 100);
  return Array.from({ length: Math.max(0, pages - 1) }, (_, offset) => ({
    params: { page: String(offset + 2) }, props: { page: offset + 2 },
  }));
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const index = readEventRankingIndex();
const ranking = readEventLiveRanking();
if (!ranking) throw new Error('Missing live event ranking');
const entries = ranking.entries.slice((page - 1) * 100, page * 100);
const localization = readLocalizationCatalog();
const totalPages = Math.ceil(ranking.entries.length / 100);
const href = (target: number) => target === 1 ? '/events/live/' : `/events/live/page/${target}/`;
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `${ranking.date} GitHub 今日实时新增 Star 排行第 ${page} 页`, numberOfItems: entries.length,
  itemListElement: entries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank,
    url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
---

<BaseLayout
  title={`GitHub 今日实时新增 Star 榜 ${page}/${totalPages}｜开源星榜`}
  description={`今日实时新增 Star Top 500 第 ${page} 页，展示第 ${entries[0]?.rank ?? 0}–${entries.at(-1)?.rank ?? 0} 名。`}
  structuredData={structuredData}
  prevPath={href(page - 1)}
  nextPath={page < totalPages ? href(page + 1) : undefined}
>
  <RankingView
    ranking={ranking} index={index} isLatest mode="event" live
    availableDates={[]} routePrefix="/events/live" dataPrefix="/data/events"
    alternateHref="/events/yesterday/" alternateLabel="查看昨日完整榜"
    switcherLabelOverride="今日实时新增榜"
    showDateTools={false} page={page} pageBasePath="/events/live/"
    rankingJsonPathOverride="/data/events/live.json"
  />
</BaseLayout>
