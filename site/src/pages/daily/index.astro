---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Initialization from '../../components/Initialization.astro';
import RankingView from '../../components/RankingView.astro';
import { readDailyRanking, readEventRankingIndex, readRankingIndex } from '../../lib/data';

const index = readRankingIndex();
const eventIndex = readEventRankingIndex();
const ranking = index.latest_date ? readDailyRanking(index.latest_date) : null;
---

<BaseLayout title="候选池 Star 净增榜｜开源星榜" description="用北京时间连续快照计算 GitHub 候选池 Star 真实净增。" socialImagePath={ranking ? `/social/daily-${ranking.date}.png` : '/og.png'}>
  {ranking ? <RankingView
    ranking={ranking}
    index={index}
    isLatest
    alternateHref={eventIndex.latest_date ? `/events/daily/${eventIndex.latest_date}/` : undefined}
    alternateLabel="查看公共事件新增榜"
  /> : <Initialization index={index} />}
</BaseLayout>
