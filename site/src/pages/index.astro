---
import BaseLayout from '../layouts/BaseLayout.astro';
import Initialization from '../components/Initialization.astro';
import RankingView from '../components/RankingView.astro';
import {
  readDailyRanking, readEventRankingIndex, readExplorationPool, readLocalizationCatalog, readRankingIndex,
} from '../lib/data';
import { localizedRepositoryContent } from '../lib/localization';
import { withBase } from '../lib/paths';

const index = readRankingIndex();
const eventIndex = readEventRankingIndex();
const ranking = index.latest_date ? readDailyRanking(index.latest_date) : null;
const exploration = ranking ? readExplorationPool('daily', ranking.date) : null;
const previousDate = ranking ? new Date(`${ranking.date}T12:00:00Z`) : null;
if (previousDate) previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate?.toISOString().slice(0, 10) ?? null;
const previousExploration = previousDateValue ? readExplorationPool('daily', previousDateValue) : null;
const localization = readLocalizationCatalog();
const firstPageEntries = ranking?.entries.slice(0, 100) ?? [];
const structuredData = ranking ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${ranking.date} GitHub 昨日净增榜`,
  numberOfItems: firstPageEntries.length,
  itemListElement: firstPageEntries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank, url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
} : undefined;
const socialImagePath = ranking ? `/social/daily-${ranking.date}.png` : '/og.png';
---

<BaseLayout
  title="开源星榜｜昨日净增榜"
  description="按 GitHub 候选池连续快照计算昨日净增排行。"
  structuredData={structuredData}
  socialImagePath={socialImagePath}
  nextPath={ranking && ranking.entries.length > 100 ? `/daily/${ranking.date}/page/2/` : undefined}
>
  {ranking ? <RankingView
    ranking={ranking}
    index={index}
    isLatest
    availableDates={index.available_dates}
    routePrefix="/daily"
    dataPrefix="/data/daily"
    alternateHref={eventIndex.latest_date ? `/events/daily/${eventIndex.latest_date}/` : '/events/daily/'}
    alternateLabel="查看全站事件新增榜"
    explorationPath={exploration ? `/data/explore/daily/${ranking.date}.json` : undefined}
    previousExplorationPath={previousExploration ? `/data/explore/daily/${previousDateValue}.json` : undefined}
    explorationEntries={exploration?.entries ?? []}
    pageBasePath={`/daily/${ranking.date}/`}
    showDateTools
  /> : <Initialization index={index} />}
</BaseLayout>
