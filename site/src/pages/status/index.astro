---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FreshnessStatus from '../../components/FreshnessStatus.astro';
import { readClassificationIndex, readLocalizationCatalog, readRankingIndex } from '../../lib/data';

const index = readRankingIndex();
const sampling = index.sampling;
const collection = index.latest_collection;
const localization = readLocalizationCatalog();
const classification = readClassificationIndex();
const formatDateTime = (value: string | null | undefined) => value
  ? new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', dateStyle: 'medium', timeStyle: 'short' }).format(new Date(value))
  : '尚无';
const reasonLabel: Record<string, string> = {
  missing: '尚无快照',
  within_window: '零点窗口内，可用于排行',
  outside_window: '零点窗口外，仅供审计',
};
const structuredData = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: '开源星榜采样与发布状态',
  dateModified: index.updated_at, temporalCoverage: 'P30D', inLanguage: 'zh-CN',
};
---

<BaseLayout title="采样与发布状态｜开源星榜" description="查看昨日净增榜的候选池覆盖、快照质量和数据完整性。" structuredData={structuredData}>
  <main id="main-content" class="shell status-page">
    <FreshnessStatus updatedAt={index.updated_at} thresholdHours={index.freshness_threshold_hours} />
    <p class="eyebrow">System status · public evidence</p>
    <h1>每次快照，<br />都可以核对。</h1>
    <p class="status-lead">昨日净增榜使用北京时间连续零点快照计算 Star 总数变化；缺失或无效窗口不会补造数据。</p>

    <section class="status-grid" aria-labelledby="pipelines-title">
      <div class="section-heading"><div><p class="eyebrow">Pipeline health</p><h2 id="pipelines-title">榜单状态</h2></div></div>
      <dl>
        <div><dt>昨日净增榜</dt><dd class:list={{ warning: sampling && !sampling.latest_snapshot_valid }}>{sampling?.latest_snapshot_valid === false ? '最新快照不合格，保留旧榜' : index.latest_date ? '最新成功榜可用' : '正在积累基线'}</dd></div>
        <div><dt>最新榜单日期</dt><dd>{index.latest_date ?? '尚无'}</dd></div>
        <div><dt>索引更新时间</dt><dd>{formatDateTime(index.updated_at)}</dd></div>
      </dl>
    </section>

    <section class="status-grid" aria-labelledby="sampling-title">
      <div class="section-heading"><div><p class="eyebrow">Candidate sampling quality</p><h2 id="sampling-title">候选池采样质量</h2></div></div>
      <dl>
        <div><dt>最近快照</dt><dd>{formatDateTime(sampling?.latest_snapshot_at)}</dd></div>
        <div><dt>质量结论</dt><dd class:list={{ warning: sampling && !sampling.latest_snapshot_valid }}>{reasonLabel[sampling?.latest_snapshot_reason ?? 'missing'] ?? sampling?.latest_snapshot_reason}</dd></div>
        <div><dt>最近有效快照</dt><dd>{formatDateTime(sampling?.latest_valid_snapshot_at)}</dd></div>
        <div><dt>有效基线</dt><dd>{sampling?.consecutive_valid_snapshots ?? 0} / 2</dd></div>
        <div><dt>下次计划采样</dt><dd>{formatDateTime(sampling?.next_scheduled_at)}</dd></div>
        <div><dt>预计首榜</dt><dd>{formatDateTime(sampling?.expected_first_ranking_at)}</dd></div>
      </dl>
    </section>

    <section class="status-grid" aria-labelledby="coverage-title">
      <div class="section-heading"><div><p class="eyebrow">Candidate collection coverage</p><h2 id="coverage-title">候选池采集覆盖</h2></div></div>
      {collection ? <dl>
        <div><dt>最近创建搜索</dt><dd>{collection.search_result_counts.recent_created.toLocaleString('zh-CN')}</dd></div>
        <div><dt>近期活跃搜索</dt><dd>{collection.search_result_counts.recent_active.toLocaleString('zh-CN')}</dd></div>
        <div><dt>成熟项目搜索</dt><dd>{collection.search_result_counts.established_active.toLocaleString('zh-CN')}</dd></div>
        <div><dt>去重新发现</dt><dd>{collection.unique_discovered_count.toLocaleString('zh-CN')}</dd></div>
        <div><dt>候选池进 / 出</dt><dd>+{collection.candidate_added_count} / −{collection.candidate_removed_count}</dd></div>
        <div><dt>API 请求 / 重试</dt><dd>{collection.api_request_count} / {collection.api_retry_count}</dd></div>
        <div><dt>快照有效 / 预期</dt><dd>{collection.snapshot_complete_count} / {collection.snapshot_expected_count}</dd></div>
        <div><dt>完整率</dt><dd>{(collection.snapshot_completeness * 100).toFixed(1)}%</dd></div>
      </dl> : <p class="empty-copy">尚未完成首次采集。</p>}
    </section>

    <section class="status-grid" aria-labelledby="progress-title">
      <div class="section-heading"><div><p class="eyebrow">Availability</p><h2 id="progress-title">真实数据积累</h2></div></div>
      <dl>
        <div><dt>日榜</dt><dd>{index.latest_date ? `已发布至 ${index.latest_date}` : `基线 ${sampling?.consecutive_valid_snapshots ?? 0}/2`}</dd></div>
        <div><dt>7 日榜</dt><dd>{sampling?.period_progress['7d'].completed ?? 0} / 7</dd></div>
        <div><dt>30 日榜</dt><dd>{sampling?.period_progress['30d'].completed ?? 0} / 30</dd></div>
        <div><dt>公共数据版本</dt><dd>{index.schema_version}</dd></div>
        <div><dt>榜单深度 / 每页</dt><dd>{index.ranking_limit ?? 100} / {index.page_size ?? 100}</dd></div>
      </dl>
    </section>

    <section class="status-grid" aria-labelledby="localization-title">
      <div class="section-heading"><div><p class="eyebrow">Project content localization</p><h2 id="localization-title">项目内容中文覆盖</h2></div></div>
      <dl>
        <div><dt>已进入公开榜单</dt><dd>{localization.coverage.eligible_count.toLocaleString('zh-CN')}</dd></div>
        <div><dt>已有有效中文内容</dt><dd>{localization.coverage.localized_count.toLocaleString('zh-CN')}</dd></div>
        <div><dt>覆盖率</dt><dd class:list={{ warning: localization.coverage.pending_count > 0 }}>{(localization.coverage.coverage_ratio * 100).toFixed(1)}%</dd></div>
        <div><dt>待生成 / 最近失败</dt><dd class:list={{ warning: localization.coverage.pending_count > 0 }}>{localization.coverage.pending_count} / {localization.coverage.failed_count}</dd></div>
        <div><dt>默认模型</dt><dd>{localization.model}</dd></div>
        <div><dt>提示词版本</dt><dd>{localization.prompt_version}</dd></div>
        <div><dt>最近整理</dt><dd>{formatDateTime(localization.generated_at)}</dd></div>
        <div><dt>回退策略</dt><dd>译文不可用时显示 GitHub 原文</dd></div>
      </dl>
    </section>

    <section class="status-grid" aria-labelledby="classification-title">
      <div class="section-heading"><div><p class="eyebrow">Project taxonomy coverage</p><h2 id="classification-title">项目分类覆盖</h2></div></div>
      <dl>
        <div><dt>已进入公开榜单</dt><dd>{classification.coverage.eligible_count.toLocaleString('zh-CN')}</dd></div>
        <div><dt>已完成分类</dt><dd>{classification.coverage.classified_count.toLocaleString('zh-CN')}</dd></div>
        <div><dt>覆盖率</dt><dd class:list={{ warning: classification.coverage.pending_count > 0 }}>{(classification.coverage.coverage_ratio * 100).toFixed(1)}%</dd></div>
        <div><dt>待分类 / 最近失败</dt><dd class:list={{ warning: classification.coverage.pending_count > 0 }}>{classification.coverage.pending_count} / {classification.coverage.failed_count}</dd></div>
        <div><dt>默认模型</dt><dd>{classification.model}</dd></div>
        <div><dt>词表 / 提示词版本</dt><dd>{classification.taxonomy_version} / {classification.prompt_version}</dd></div>
        <div><dt>最近整理</dt><dd>{formatDateTime(classification.generated_at)}</dd></div>
        <div><dt>回退策略</dt><dd>分类不可用时标记待生成，不影响榜单</dd></div>
      </dl>
    </section>
  </main>
</BaseLayout>
