---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RankingView from '../../../components/RankingView.astro';
import { readExplorationPool, readLocalizationCatalog, readPeriodRanking, readRankingIndex } from '../../../lib/data';
import { localizedRepositoryContent } from '../../../lib/localization';

export const getStaticPaths = (() => {
  const index = readRankingIndex();
  return ([7, 30] as const).flatMap((days) =>
    (index.periods?.[`${days}d`]?.available_dates ?? []).map((date) => ({
      params: { range: `${days}d`, date }, props: { days, date },
    })),
  );
}) satisfies GetStaticPaths;

const { days, date } = Astro.props;
const index = readRankingIndex();
const ranking = readPeriodRanking(days, date);
const explorationKind = days === 7 ? 'period_7d' : 'period_30d';
const exploration = readExplorationPool(explorationKind, date);
const previousDate = new Date(`${date}T12:00:00Z`);
previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate.toISOString().slice(0, 10);
const previousExploration = readExplorationPool(explorationKind, previousDateValue);
const localization = readLocalizationCatalog();
const dates = index.periods?.[`${days}d`]?.available_dates ?? [];
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList', name: `${date} GitHub 近 ${days} 日 Star 净增榜`,
  numberOfItems: ranking.entries.length,
  itemListElement: ranking.entries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank, url: entry.html_url,
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
---

<BaseLayout title={`${date} GitHub 近 ${days} 日 Star 榜｜开源星榜`} structuredData={structuredData} socialImagePath={`/social/period-${days}d-${date}.png`}>
  <RankingView ranking={ranking} index={index} mode="period" isLatest={date === index.periods?.[`${days}d`]?.latest_date} availableDates={dates} routePrefix={`/period/${days}d`} dataPrefix={`/data/period/${days}d`} explorationPath={exploration ? `/data/explore/period/${days}d/${date}.json` : undefined} previousExplorationPath={previousExploration ? `/data/explore/period/${days}d/${previousDateValue}.json` : undefined} explorationEntries={exploration?.entries ?? []} />
</BaseLayout>
