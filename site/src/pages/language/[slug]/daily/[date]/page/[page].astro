---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../../../layouts/BaseLayout.astro';
import RankingView from '../../../../../../components/RankingView.astro';
import { readExplorationPool, readLanguageIndex, readLanguageRanking, readLocalizationCatalog, readRankingIndex } from '../../../../../../lib/data';
import { localizedRepositoryContent } from '../../../../../../lib/localization';
import { withBase } from '../../../../../../lib/paths';

export const getStaticPaths = (() => {
  const languages = readLanguageIndex();
  return languages.languages.flatMap((language) => language.available_dates.flatMap((date) => {
    const ranking = readLanguageRanking(language.slug, date);
    const pages = Math.ceil(ranking.entries.length / 100);
    return Array.from({ length: Math.max(0, pages - 1) }, (_, offset) => ({
      params: { slug: language.slug, date, page: String(offset + 2) },
      props: { language, date, page: offset + 2 },
    }));
  }));
}) satisfies GetStaticPaths;

const { language, date, page } = Astro.props;
const index = readRankingIndex();
const ranking = readLanguageRanking(language.slug, date);
const exploration = readExplorationPool('daily', date);
const previousDate = new Date(`${date}T12:00:00Z`);
previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate.toISOString().slice(0, 10);
const previousExploration = readExplorationPool('daily', previousDateValue);
const localization = readLocalizationCatalog();
const entries = ranking.entries.slice((page - 1) * 100, page * 100);
const totalPages = Math.ceil(ranking.entries.length / 100);
const basePath = `/language/${language.slug}/daily/${date}/`;
const href = (target: number) => target === 1 ? basePath : `${basePath}page/${target}/`;
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `${date} ${language.language} GitHub Star 净增榜第 ${page} 页`, numberOfItems: entries.length,
  itemListElement: entries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank,
    url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
---

<BaseLayout
  title={`${date} ${language.language} GitHub Star 榜 ${page}/${totalPages}｜开源星榜`}
  description={`${date} ${language.language} Star 净增 Top 500 第 ${page} 页。`}
  structuredData={structuredData} socialImagePath={`/social/language-${language.slug}-${date}.png`}
  prevPath={href(page - 1)} nextPath={page < totalPages ? href(page + 1) : undefined}
>
  <RankingView
    ranking={ranking} index={index} mode="language" isLatest={date === language.latest_date}
    availableDates={language.available_dates} routePrefix={`/language/${language.slug}/daily`}
    dataPrefix={`/data/language/${language.slug}/daily`} fixedLanguage={language.language}
    explorationPath={exploration ? `/data/explore/daily/${date}.json` : undefined}
    previousExplorationPath={previousExploration ? `/data/explore/daily/${previousDateValue}.json` : undefined}
    explorationEntries={exploration?.entries ?? []} page={page} pageBasePath={basePath}
  />
</BaseLayout>
