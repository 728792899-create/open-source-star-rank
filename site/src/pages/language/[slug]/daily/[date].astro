---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import RankingView from '../../../../components/RankingView.astro';
import { readExplorationPool, readLanguageIndex, readLanguageRanking, readLocalizationCatalog, readRankingIndex } from '../../../../lib/data';
import { localizedRepositoryContent } from '../../../../lib/localization';
import { withBase } from '../../../../lib/paths';

export const getStaticPaths = (() => {
  const languages = readLanguageIndex();
  return languages.languages.flatMap((language) => language.available_dates.map((date) => ({
    params: { slug: language.slug, date }, props: { language, date },
  })));
}) satisfies GetStaticPaths;

const { language, date } = Astro.props;
const index = readRankingIndex();
const ranking = readLanguageRanking(language.slug, date);
const exploration = readExplorationPool('daily', date);
const previousDate = new Date(`${date}T12:00:00Z`);
previousDate.setUTCDate(previousDate.getUTCDate() - 1);
const previousDateValue = previousDate.toISOString().slice(0, 10);
const previousExploration = readExplorationPool('daily', previousDateValue);
const localization = readLocalizationCatalog();
const firstPageEntries = ranking.entries.slice(0, 100);
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ItemList', name: `${date} ${language.language} GitHub Star 净增榜`,
  numberOfItems: firstPageEntries.length,
  itemListElement: firstPageEntries.map((entry) => ({
    '@type': 'ListItem', position: entry.rank, url: new URL(withBase(`/repo/${entry.repository_id}/`), Astro.site ?? Astro.url.origin).toString(),
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
};
---

<BaseLayout
  title={`${date} ${language.language} GitHub Star 榜｜开源星榜`}
  description={`${date} ${language.language} GitHub 开源项目独立 Star 净增 Top ${ranking.entries.length}。`}
  structuredData={structuredData}
  socialImagePath={`/social/language-${language.slug}-${date}.png`}
  nextPath={ranking.entries.length > 100 ? `/language/${language.slug}/daily/${date}/page/2/` : undefined}
>
  <RankingView
    ranking={ranking}
    index={index}
    mode="language"
    isLatest={date === language.latest_date}
    availableDates={language.available_dates}
    routePrefix={`/language/${language.slug}/daily`}
    dataPrefix={`/data/language/${language.slug}/daily`}
    fixedLanguage={language.language}
    explorationPath={exploration ? `/data/explore/daily/${date}.json` : undefined}
    previousExplorationPath={previousExploration ? `/data/explore/daily/${previousDateValue}.json` : undefined}
    explorationEntries={exploration?.entries ?? []}
    pageBasePath={`/language/${language.slug}/daily/${date}/`}
  />
</BaseLayout>
