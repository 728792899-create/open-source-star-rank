---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RankingView from '../../components/RankingView.astro';
import { classificationMap } from '../../lib/classification';
import {
  readClassificationIndex, readClassificationRepositories, readEventRankingIndex,
  readLatestEventCategoryPool, readLocalizationCatalog,
} from '../../lib/data';
import { buildFacetRanking } from '../../lib/facet-rankings';
import { localizedRepositoryContent } from '../../lib/localization';
import { withBase } from '../../lib/paths';

export const getStaticPaths = (() => readClassificationIndex().categories.map((category) => ({
  params: { slug: category.id },
  props: { category },
}))) satisfies GetStaticPaths;

const { category } = Astro.props;
const eventIndex = readEventRankingIndex();
const pool = readLatestEventCategoryPool();
const classifications = classificationMap(readClassificationRepositories());
const localization = readLocalizationCatalog();
const ranking = pool ? buildFacetRanking(pool, classifications, 'category', category.id) : null;
const hasProjects = Boolean(ranking?.entries.length);
const structuredData = hasProjects ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${category.label} GitHub 开源项目｜分类独立榜`,
  numberOfItems: ranking!.entries.length,
  itemListElement: ranking!.entries.map((entry) => ({
    '@type': 'ListItem',
    position: entry.rank,
    url: entry.html_url,
    name: localizedRepositoryContent(localization, entry.repository_id, entry.full_name, entry.description).displayName,
  })),
} : undefined;
---

<BaseLayout
  title={`${category.label} 独立榜｜开源星榜`}
  description={`“${category.label}”方向的独立前 100 榜，按 GH Archive 每日新增 Star 在分类内重新排名。`}
  structuredData={structuredData}
  robots={hasProjects ? 'index,follow' : 'noindex,follow'}
>
  {hasProjects ? <RankingView
    ranking={ranking!}
    index={eventIndex}
    isLatest
    mode="event"
    variant="facet"
    showDateTools={false}
    downloadable={false}
    headlineOverride={`${category.label}，昨日哪些项目新增 Star 最多？`}
    sectionEyebrowOverride={`Direction board · ${category.id}`}
    sectionTitleOverride={`${category.label}·分类独立榜`}
    switcherLabelOverride={`${category.label}·分类独立榜`}
    alternateHref="/"
    alternateLabel="返回全部榜单"
    rankingPathOverride={`/category/${category.id}/`}
  /> : <main id="main-content" class="shell language-page category-page">
    <nav class="ranking-mode-switcher" aria-label="榜单口径">
      <strong>{category.label}·分类独立榜</strong>
      <a href={withBase('/')}>返回全部榜单 →</a>
    </nav>
    <p class="eyebrow">Direction board · {category.id}</p>
    <h1>{category.label}</h1>
    <p class="empty-copy">该方向暂无进入扩展候选池的项目。榜单发布并完成分类后，这里会自动显示“{category.label}”的独立前 100。</p>
    <p><a href={withBase('/board/')}>浏览全部分类独立榜 →</a></p>
  </main>}
</BaseLayout>
