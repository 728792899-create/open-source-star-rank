---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { classificationMap } from '../../lib/classification';
import {
  readClassificationIndex, readClassificationRepositories, readEventRankingIndex, readLatestEventCategoryPool,
} from '../../lib/data';
import { facetCounts } from '../../lib/facet-rankings';
import { withBase } from '../../lib/paths';

const classificationIndex = readClassificationIndex();
const classifications = classificationMap(readClassificationRepositories());
const pool = readLatestEventCategoryPool();
const eventIndex = readEventRankingIndex();
const counts = pool
  ? facetCounts(pool, classifications, 'category', classificationIndex.categories.map((term) => term.id))
  : new Map<string, number>();
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'GitHub 开源项目方向分类独立榜',
  description: '按项目方向浏览各自独立的每日新增 Star 前 100 榜。',
  hasPart: classificationIndex.categories.map((term) => ({
    '@type': 'ItemList',
    name: term.label,
    numberOfItems: counts.get(term.id) ?? 0,
    url: new URL(withBase(`/category/${term.id}/`), Astro.site ?? Astro.url.origin).toString(),
  })),
};
---

<BaseLayout
  title="GitHub 开源项目方向分类独立榜｜开源星榜"
  description="按 AI、开发者工具、Web、数据基础设施等方向，浏览各自独立的每日新增 Star 前 100 榜。"
  structuredData={structuredData}
>
  <main id="main-content" class="shell language-page category-page">
    <p class="eyebrow">Direction boards · daily gain</p>
    <h1>不只看语言，<br />也看项目解决什么。</h1>
    <p class="status-lead">每个方向都有自己独立的「每日新增 Star 前 100」榜，名次在方向内重新排序，不再只是全站榜的子集。{eventIndex.status === 'ready' ? '当前口径：全站公开事件新增榜的扩展候选池。' : '扩展候选池发布后自动生效。'}</p>
    <p class="status-lead"><a href={withBase('/board/')}>查看全部四个维度的独立榜（语言 · 方向 · 形态 · 场景）→</a> · <a href={withBase('/all-time/')}>全部历史星标 Top 1000 →</a></p>

    <section class="language-list" aria-labelledby="category-list-title">
      <div class="section-heading"><div><p class="eyebrow">Fixed taxonomy 1.0</p><h2 id="category-list-title">项目方向</h2></div><strong>{classificationIndex.categories.length}</strong></div>
      <div class="language-cards category-cards">
        {classificationIndex.categories.map((term) => <a href={withBase(`/category/${term.id}/`)}>
          <span>{term.label}</span>
          <strong>{counts.get(term.id) ?? 0} 个项目</strong>
          <small>{(counts.get(term.id) ?? 0) > 0 ? '查看独立榜 →' : '暂无入池项目'}</small>
        </a>)}
      </div>
    </section>
  </main>
</BaseLayout>
