{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:4323/open-source-star-rank/daily/2026-07-14/"],
      "startServerCommand": "PORT=4323 BASE_PATH=/open-source-star-rank node scripts/serve-static.mjs",
      "startServerReadyPattern": "Local",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
