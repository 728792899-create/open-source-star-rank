{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://728792899-create.github.io/open-source-star-rank/data/schema/classification-index.schema.json",
  "title": "Open Source Star Rank classification index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "taxonomy_version", "locale", "generated_at", "model", "prompt_version", "coverage", "categories", "project_types", "use_cases"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "taxonomy_version": { "const": "1.0.0" },
    "locale": { "const": "zh-CN" },
    "generated_at": { "type": ["string", "null"], "format": "date-time" },
    "model": { "type": "string", "minLength": 1, "maxLength": 120 },
    "prompt_version": { "const": "repository-classification-v1" },
    "coverage": { "$ref": "#/$defs/coverage" },
    "categories": { "type": "array", "minItems": 13, "maxItems": 13, "items": { "$ref": "#/$defs/term" } },
    "project_types": { "type": "array", "minItems": 8, "maxItems": 8, "items": { "$ref": "#/$defs/term" } },
    "use_cases": { "type": "array", "minItems": 31, "maxItems": 31, "items": { "$ref": "#/$defs/term" } }
  },
  "$defs": {
    "term": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligible_count", "classified_count", "pending_count", "failed_count", "coverage_ratio"],
      "properties": {
        "eligible_count": { "type": "integer", "minimum": 0 },
        "classified_count": { "type": "integer", "minimum": 0 },
        "pending_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
