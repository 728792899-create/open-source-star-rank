{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://728792899-create.github.io/open-source-star-rank/data/schema/state.schema.json",
  "title": "Open Source Star Rank candidate state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "candidate_count", "candidates"],
  "properties": {
    "schema_version": { "enum": ["1.1.0", "1.2.0"] },
    "updated_at": { "type": "string", "format": "date-time" },
    "candidate_count": { "type": "integer", "minimum": 1, "maximum": 2000 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id", "full_name", "description", "language", "stars_total", "html_url", "owner_avatar_url", "created_at", "pushed_at", "archived", "disabled", "fork", "first_seen_date", "last_seen_date", "last_refreshed_date", "discovery_sources", "pinned"],
      "properties": {
        "repository_id": { "type": "integer", "minimum": 1 },
        "full_name": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "description": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "stars_total": { "type": "integer", "minimum": 0 },
        "html_url": { "type": "string", "format": "uri", "pattern": "^https://github\\.com/" },
        "owner_avatar_url": { "type": ["string", "null"], "format": "uri" },
        "created_at": { "type": ["string", "null"], "format": "date-time" },
        "pushed_at": { "type": ["string", "null"], "format": "date-time" },
        "archived": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "fork": { "type": "boolean" },
        "first_seen_date": { "type": "string", "format": "date" },
        "last_seen_date": { "type": "string", "format": "date" },
        "last_refreshed_date": { "type": "string", "format": "date" },
        "discovery_sources": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "pinned": { "type": "boolean" }
      }
    }
  }
}
