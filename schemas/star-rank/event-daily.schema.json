{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://728792899-create.github.io/open-source-star-rank/data/schema/event-daily.schema.json",
  "title": "Open Source Star Rank global public WatchEvent daily ranking",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "date", "timezone", "window_start", "window_end", "generated_at",
    "methodology_version", "source_metrics", "eligible_count", "entries"
  ],
  "properties": {
    "schema_version": { "enum": ["1.0.0", "1.1.0", "1.2.0", "1.3.0"] },
    "ranking_limit": { "const": 500 },
    "entry_count": { "const": 500 },
    "recomputed_at": { "type": "string", "format": "date-time" },
    "date": { "$ref": "#/$defs/date" },
    "timezone": { "const": "Asia/Shanghai" },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "methodology_version": { "enum": ["gharchive-public-watch-events-v1", "gharchive-public-watch-events-v2", "gharchive-public-watch-events-v3"] },
    "source_metrics": { "$ref": "#/$defs/source_metrics" },
    "eligible_count": { "type": "integer", "minimum": 100, "maximum": 900 },
    "entries": {
      "type": "array",
      "minItems": 100,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.0.0" } }, "required": ["schema_version"] },
      "then": { "properties": { "methodology_version": { "const": "gharchive-public-watch-events-v1" } } },
      "else": {}
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.1.0" } }, "required": ["schema_version"] },
      "then": {
        "properties": {
          "methodology_version": { "const": "gharchive-public-watch-events-v2" },
          "source_metrics": { "$ref": "#/$defs/source_metrics_v2" },
          "eligible_count": { "const": 100 },
          "entries": { "minItems": 100, "maxItems": 100 }
        }
      }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.2.0" } }, "required": ["schema_version"] },
      "then": {
        "required": ["ranking_limit", "entry_count"],
        "properties": {
          "methodology_version": { "const": "gharchive-public-watch-events-v3" },
          "source_metrics": { "$ref": "#/$defs/source_metrics_v3" },
          "eligible_count": { "const": 500 },
          "entries": { "minItems": 500, "maxItems": 500 }
        }
      }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.3.0" } }, "required": ["schema_version"] },
      "then": {
        "required": ["ranking_limit", "entry_count"],
        "properties": {
          "methodology_version": { "const": "gharchive-public-watch-events-v3" },
          "source_metrics": { "$ref": "#/$defs/source_metrics_v3" },
          "eligible_count": { "const": 500 },
          "entries": { "minItems": 500, "maxItems": 500 }
        }
      }
    }
  ],
  "$defs": {
    "date": { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider", "dataset", "table_dates", "estimated_bytes", "bytes_processed",
        "maximum_bytes_billed", "observed_watch_event_count", "observed_repository_count",
        "metadata_attempted_count", "metadata_success_count", "metadata_not_found_count",
        "metadata_filtered_count", "api_request_count", "api_retry_count"
      ],
      "properties": {
        "provider": { "const": "gh_archive_bigquery" },
        "dataset": { "const": "githubarchive.day" },
        "scope": { "const": "github_public_events_as_archived_by_gh_archive" },
        "counting_unit": { "const": "unique_actor_repository_pair" },
        "table_dates": {
          "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
          "items": { "type": "string", "pattern": "^\\d{8}$" }
        },
        "expected_hour_count": { "const": 24 },
        "observed_hour_count": { "type": "integer", "minimum": 0, "maximum": 24 },
        "missing_hours": {
          "type": "array", "maxItems": 24, "uniqueItems": true,
          "items": { "type": "string", "format": "date-time" }
        },
        "estimated_bytes": { "type": "integer", "minimum": 0, "maximum": 25769803776 },
        "bytes_processed": { "type": "integer", "minimum": 0, "maximum": 25769803776 },
        "maximum_bytes_billed": { "type": "integer", "minimum": 1, "maximum": 25769803776 },
        "unique_star_addition_count": { "type": "integer", "minimum": 1 },
        "observed_watch_event_count": { "type": "integer", "minimum": 0 },
        "observed_repository_count": { "type": "integer", "minimum": 0 },
        "ranking_complete": { "const": true },
        "quality_baseline_days": { "type": "integer", "minimum": 0, "maximum": 7 },
        "watch_event_count_median": { "type": ["integer", "null"], "minimum": 1 },
        "unique_addition_count_median": { "type": ["integer", "null"], "minimum": 1 },
        "watch_event_count_ratio": { "type": ["number", "null"], "minimum": 0 },
        "unique_addition_count_ratio": { "type": ["number", "null"], "minimum": 0 },
        "quality_status": { "enum": ["calibrating", "passed"] },
        "metadata_attempted_count": { "type": "integer", "minimum": 0, "maximum": 900 },
        "metadata_success_count": { "type": "integer", "minimum": 0, "maximum": 900 },
        "metadata_not_found_count": { "type": "integer", "minimum": 0, "maximum": 900 },
        "metadata_filtered_count": { "type": "integer", "minimum": 0, "maximum": 900 },
        "api_request_count": { "type": "integer", "minimum": 0, "maximum": 950 },
        "api_retry_count": { "type": "integer", "minimum": 0 }
      }
    },
    "source_metrics_v2": {
      "allOf": [
        { "$ref": "#/$defs/source_metrics" },
        {
          "required": [
            "scope", "counting_unit", "expected_hour_count", "observed_hour_count",
            "missing_hours", "unique_star_addition_count", "ranking_complete"
          ]
        }
      ]
    },
    "source_metrics_v3": {
      "allOf": [
        { "$ref": "#/$defs/source_metrics_v2" },
        {
          "required": [
            "quality_baseline_days", "watch_event_count_median", "unique_addition_count_median",
            "watch_event_count_ratio", "unique_addition_count_ratio", "quality_status"
          ]
        }
      ]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_id", "full_name", "description", "language", "stars_total", "stars_added",
        "watch_events", "rank", "rank_change", "trend_7d", "html_url", "owner_avatar_url"
      ],
      "properties": {
        "repository_id": { "type": "integer", "minimum": 1 },
        "full_name": { "type": "string", "minLength": 3, "pattern": "^[^/]+/[^/]+$" },
        "description": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "stars_total": { "type": "integer", "minimum": 0 },
        "created_at": { "type": ["string", "null"], "format": "date-time" },
        "pushed_at": { "type": ["string", "null"], "format": "date-time" },
        "stars_added": { "type": "integer", "minimum": 1 },
        "watch_events": { "type": "integer", "minimum": 1 },
        "rank": { "type": "integer", "minimum": 1, "maximum": 500 },
        "rank_change": { "type": ["integer", "null"] },
        "trend_7d": {
          "type": "array", "minItems": 7, "maxItems": 7,
          "items": { "type": ["integer", "null"], "minimum": 0 }
        },
        "html_url": { "type": "string", "format": "uri", "pattern": "^https://github\\.com/" },
        "owner_avatar_url": { "type": ["string", "null"], "format": "uri" }
      }
    }
  }
}
