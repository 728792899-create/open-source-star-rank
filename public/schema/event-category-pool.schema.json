{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://728792899-create.github.io/open-source-star-rank/data/schema/event-category-pool.schema.json",
  "title": "Open Source Star Rank extended daily-gain pool for independent facet boards",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "date", "timezone", "window_start", "window_end", "generated_at",
    "methodology_version", "pool_size", "entries"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "date": { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "timezone": { "const": "Asia/Shanghai" },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "methodology_version": { "enum": ["gharchive-public-watch-events-v1", "gharchive-public-watch-events-v2"] },
    "pool_size": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_id", "full_name", "description", "language", "stars_total", "stars_added",
        "watch_events", "rank", "html_url", "owner_avatar_url"
      ],
      "properties": {
        "repository_id": { "type": "integer", "minimum": 1 },
        "full_name": { "type": "string", "minLength": 3, "pattern": "^[^/]+/[^/]+$" },
        "description": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "stars_total": { "type": "integer", "minimum": 0 },
        "stars_added": { "type": "integer", "minimum": 1 },
        "watch_events": { "type": "integer", "minimum": 1 },
        "rank": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "html_url": { "type": "string", "format": "uri", "pattern": "^https://github\\.com/" },
        "owner_avatar_url": { "type": ["string", "null"], "format": "uri" }
      }
    }
  }
}
