{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://728792899-create.github.io/open-source-star-rank/data/schema/language-index.schema.json",
  "title": "Open Source Star Rank language index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "timezone", "languages"],
  "properties": {
    "schema_version": { "const": "1.2.0" },
    "updated_at": { "type": "string", "format": "date-time" },
    "timezone": { "const": "Asia/Shanghai" },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["language", "slug", "candidate_count", "latest_date", "available_dates", "status"],
        "properties": {
          "language": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "candidate_count": { "type": "integer", "minimum": 1, "maximum": 2000 },
          "latest_date": { "type": ["string", "null"], "format": "date" },
          "available_dates": { "type": "array", "uniqueItems": true, "items": { "type": "string", "format": "date" } },
          "status": { "enum": ["accumulating", "ready"] }
        }
      }
    }
  }
}
